# Learn Hermes Agent — 环境配置
# 复制此文件为 .env，填写你的 API 信息后运行教学代码

# API Base URL（支持任意 OpenAI SDK 兼容接口）
# 示例：OpenAI 官方：https://api.openai.com/v1
#       本地 Ollama：http://localhost:11434/v1
#       通过代理的 Claude：https://your-proxy/v1
HERMES_BASE_URL=https://api.openai.com/v1

# API Key
HERMES_API_KEY=sk-...

# 模型名称（需与 base_url 的服务商匹配）
HERMES_MODEL=gpt-4o
